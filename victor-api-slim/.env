# Your existing MQTT broker
MQTT_HOST=192.168.1.100
MQTT_PORT=1883
MQTT_USER=your_mqtt_user
MQTT_PASS=your_mqtt_password
MQTT_PREFIX=victor

# Device token map — one entry per trap
# Get token: curl -X POST https://www.victorsmarthost.com/api-token-auth/
#                 -H "Content-Type: application/json"
#                 -d '{"username":"<serial>","password":"<password>"}'
# Format: SERIAL1:TOKEN1,SERIAL2:TOKEN2
DEVICE_TOKENS=WM201027GV00000:your_real_token_here
