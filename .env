# --- Server ---
# Port to listen on
PORT=8080

# SSL mode: uncomment and set paths to enable TLS directly in uvicorn
# Leave commented to run plain HTTP behind your existing reverse proxy
#SSL_CERTFILE=/certs/cert.pem
#SSL_KEYFILE=/certs/key.pem

# --- MQTT broker ---
MQTT_HOST=192.168.1.100
MQTT_PORT=1883
MQTT_USER=your_mqtt_user
MQTT_PASS=your_mqtt_password
MQTT_PREFIX=victor

# --- Device tokens ---
# One entry per trap. Format: SERIAL1:TOKEN1,SERIAL2:TOKEN2
#
# Find your device serial and password by provisioning the trap and
# watching the /api-token-auth/ request in your logs.
#
# Exchange them for a token while the original API is still live:
#   curl -X POST https://www.victorsmarthost.com/api-token-auth/ \
#        -H "Content-Type: application/json" \
#        -d '{"username":"<serial>","password":"<password>"}'
#
DEVICE_TOKENS=<device_serial>:<device_token>
